# Scheduler Microservice Environment Variables
# Copy to .env and fill in values for local development

# API security — shared secret with main app
SCHEDULER_API_KEY=your-strong-random-api-key

# Google Calendar
# Paste the full JSON content of your GCP service account key here (as a single line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"change-navigator",...}

# The Google Calendar ID to use for bookings
# Find it in Google Calendar settings > "Integrate calendar"
CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Timezone for working hours and slot display
SCHEDULER_TIMEZONE=Asia/Jerusalem

# Working hours (24h format) in SCHEDULER_TIMEZONE
WORKING_HOURS_START=09:00
WORKING_HOURS_END=18:00

# Port (auto-set by Cloud Run, use 8080 locally)
PORT=8080
